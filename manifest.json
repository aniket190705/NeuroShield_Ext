{
  "manifest_version": 3,
  "name": "Fatigue Tracker",
  "version": "1.0.0",
  "background": {
    "service_worker": "service-worker.js"
  },
  "host_permissions": [
    "http://localhost:3000/*",
    "http://127.0.0.1:3000/*",
    "http://[::1]:3000/*"
  ],
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["tracker.js"],
      "run_at": "document_start"
    }
  ]
}
